# Supabase (Production)
# Get these from your Supabase project dashboard
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Generate at: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Click "Generate new key" for service_role key
NEXT_PUBLIC_SUPABASE_AUTH_SECRET=your_generated_jwt_secret_min_32_chars

# OpenAI API Key (for embeddings - required for RAG)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# Anthropic API Key (optional - for Claude integration)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Application URL (for production)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Rate Limiting (optional)
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
